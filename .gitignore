# .gitignore — файлы и директории, которые Git не должен отслеживать.

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/          # скомпилированные байткод-файлы Python (.pyc)
*.py[cod]             # .pyc, .pyo, .pyd
*.pyo
*.pyd
*.so                  # скомпилированные расширения C (Linux/macOS)

# ---------------------------------------------------------------------------
# Виртуальное окружение
# ---------------------------------------------------------------------------
venv/
.venv/
env/
.env/

# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------
db.sqlite3            # файл базы данных SQLite — у каждого разработчика свой
*.sqlite3
staticfiles/          # папка collectstatic (генерируется автоматически)
mediafiles/           # загружаемые пользователями файлы

# ---------------------------------------------------------------------------
# IDE и редакторы
# ---------------------------------------------------------------------------
.idea/                # PyCharm
.vscode/              # VS Code
*.swp                 # Vim swap-файлы
.DS_Store             # macOS Finder metadata

# ---------------------------------------------------------------------------
# Переменные окружения (секреты!)
# ---------------------------------------------------------------------------
.env                  # SECRET_KEY, пароли БД — НИКОГДА не коммитить!
*.env

# ---------------------------------------------------------------------------
# Архивы (временные)
# ---------------------------------------------------------------------------
*.zip
*.tar.gz
